# Drizzle
DATABASE_URL="postgres://root:mysecretpassword@localhost:5432/local"

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# Novem leaderboard embed (public iframe URL). Leave empty for a placeholder.
PUBLIC_LEADERBOARD_EMBED_URL=""

# football-data.org API token, used to refresh the saved snapshot under
# src/lib/server/data/fixtures. Register for a free token at
# https://www.football-data.org/client/register — keep the real value in
# your local .env (gitignored), never commit it.
FOOTBALL_DATA_TOKEN=""

# API-Football (https://www.api-football.com) — used by `pnpm db:ingest` to load
# the real player pool. League 1 = World Cup; season is the tournament year.
API_FOOTBALL_KEY=""
API_FOOTBALL_LEAGUE_ID="1"
API_FOOTBALL_SEASON="2022"
